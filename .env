# Environment Configuration
# This file is used by Symfony to configure the application

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme_in_production_with_random_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://lpmde:lpmde@db:5432/lpmde?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null

###> keycloak configuration ###
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_PUBLIC_URL=http://localhost:8081
KEYCLOAK_REALM=lpmde
KEYCLOAK_CLIENT_ID=symfony-app
KEYCLOAK_CLIENT_SECRET=change_me
KEYCLOAK_REDIRECT_URI=https://localhost:8443/login/keycloak/callback
###< keycloak configuration ###
###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

# Liste CSV des comptes admin (persistés en ROLE_ADMIN à la connexion)
ADMIN_EMAILS=admin@example.com

# Variables optionnelles si vous souhaitez composer DATABASE_URL dynamiquement
# DB_USER=lpmde
# DB_PASSWORD=lpmde
