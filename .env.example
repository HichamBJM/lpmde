# Environment Configuration Example
# Copier ce fichier en .env.local et adapter les valeurs

APP_ENV=dev
APP_SECRET=change_this_secret_in_production

# Application DB (PostgreSQL)
DATABASE_URL="postgresql://lpmde:lpmde@127.0.0.1:5432/lpmde?serverVersion=16&charset=utf8"

# Messenger
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@127.0.0.1:5672/%2f/messages

# Keycloak
KEYCLOAK_URL=http://127.0.0.1:8081
KEYCLOAK_PUBLIC_URL=http://127.0.0.1:8081
KEYCLOAK_REALM=lpmde
KEYCLOAK_CLIENT_ID=symfony-app
KEYCLOAK_CLIENT_SECRET=replace_with_client_secret
KEYCLOAK_REDIRECT_URI=https://localhost:8443/login/keycloak/callback

# Admins CSV
ADMIN_EMAILS=admin@lpmde.local
